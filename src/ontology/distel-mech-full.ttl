                                          "Kelvin"@it ,
                                          "Kelvin"@la ,
                                          "Kelvin"@ms ,
                                          "Kelvin"@pt ,
                                          "Kelvin"@ro ,
                                          "Kelvin"@sl ,
                                          "Kelvin"@tr ,
