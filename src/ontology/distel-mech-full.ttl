                                                                                                  co:PMD_0025020
                                                                                                )
                                                                                  ]
                                                             ] ;
                                             rdfs:label "fatigue control type"@en ;
                                             skos:definition "Fatigue control type is a process attribute of a fatigue testing  which describes the variable (stress or strain) that remains constant during the fatigue testing."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000013
<https://w3id.org/pmd/distel/DISTEL_0000013> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000008 ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty co:PMD_0025006 ;
                                                               owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                    owl:unionOf ( co:PMD_0000638
                                                                                                  co:PMD_0025020
                                                                                                )
                                                                                  ]
                                                             ] ;
                                             rdfs:label "fatigue waveform"@en ;
                                             skos:definition "Fatigue waveform is a process attribute of a fatigue testing which describes the shape of a mechanical acuation signal (load)."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000014
<https://w3id.org/pmd/distel/DISTEL_0000014> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0025007 ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty co:PMD_0025006 ;
                                                               owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                    owl:unionOf ( co:PMD_0000638
                                                                                                  co:PMD_0025020
                                                                                                )
                                                                                  ]
                                                             ] ;
                                             rdfs:label "fatigue testing frequency"@en ;
                                             skos:definition "Fatigue testing frequency is a process attribute of a fatigue testing which indicates how many loading cycles the sample experiences within a second."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000017
<https://w3id.org/pmd/distel/DISTEL_0000017> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000952 ;
                                             rdfs:label "fatigue strength"@en ;
                                             skos:definition "Fatigue strength is a strength which is realized in the fatigue process and desribes the maximum cyclic stress amplitude that a material can withstand without failure."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000018
<https://w3id.org/pmd/distel/DISTEL_0000018> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000008 ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty co:PMD_0025006 ;
                                                               owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                    owl:unionOf ( co:PMD_0000638
                                                                                                  co:PMD_0025020
                                                                                                )
                                                                                  ]
                                                             ] ;
                                             rdfs:label "loading amplitude"@en ;
                                             skos:definition "Loading amplitude is a maximal difference between a minimal and maximal stress or strain (depending on the fatigue control type) that the specimen experiences during a fatigue testing."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000019
<https://w3id.org/pmd/distel/DISTEL_0000019> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000008 ;
                                             rdfs:label "fatigue mean stress"@en ;
                                             skos:definition "Fatigue mean stress is a average value of a stress that the specimen experiences during fatigue testing."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000020
<https://w3id.org/pmd/distel/DISTEL_0000020> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000008 ;
                                             rdfs:comment "TODO write axioms for the specific loading ratios" ;
                                             rdfs:label "loading ratio"@en ;
                                             skos:definition "Loading ratio is a process attribute of a fatigue testing which describes the ratio between the minimal and the maximal value of some physical quality, namely stress, strain, or load."@en ;
                                             co:symbol "R" .


###  https://w3id.org/pmd/distel/DISTEL_0000021
<https://w3id.org/pmd/distel/DISTEL_0000021> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/pmd/distel/DISTEL_0000020> ;
                                             rdfs:label "stress ratio"@en ;
                                             skos:definition "Stress ratio is a loading ratio process attribute of a fatigue test which is determined as a ratio between the maximum and minimum value of a stress applied to the specimen."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000022
<https://w3id.org/pmd/distel/DISTEL_0000022> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/pmd/distel/DISTEL_0000020> ;
                                             rdfs:label "strain ratio"@en ;
                                             skos:definition "Strain ratio is a loading ratio process attribute of a fatigue test which is determined as a ratio between the maximum and minimum value of a strain which the specimen experiences."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000023
<https://w3id.org/pmd/distel/DISTEL_0000023> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/pmd/distel/DISTEL_0000020> ;
                                             rdfs:label "load ratio"@en ;
                                             skos:altLabel "force ratio"@en ;
                                             skos:definition "Load ratio is a loading ratio process attribute of a fatigue test which is determined as a ratio between the maximum and minimum value of an applied load (force)."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000024
<https://w3id.org/pmd/distel/DISTEL_0000024> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/pmd/distel/DISTEL_0000018> ;
                                             rdfs:label "stress amplitude"@en ;
                                             skos:definition "Stress amplitude is a maximal difference between a minimal and maximal stress that the specimen experiences during a fatigue testing."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000025
<https://w3id.org/pmd/distel/DISTEL_0000025> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/pmd/distel/DISTEL_0000018> ;
                                             rdfs:label "strain amplitude"@en ;
                                             skos:definition "Strain amplitude is a maximal difference between a minimal and maximal strain that the specimen experiences during a fatigue testing."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000026
<https://w3id.org/pmd/distel/DISTEL_0000026> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000008 ;
                                             rdfs:label "fatigue maximum stress"@en ;
                                             skos:definition "Fatigue maximum stress is a process attribute of a fatigue testing process which describes the maximum stress that the specimen experiences. Its value corresponds to the max peak of a fatigue waveform."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000027
<https://w3id.org/pmd/distel/DISTEL_0000027> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000008 ;
                                             rdfs:label "fatigue minimum stress"@en ;
                                             skos:definition "Fatigue minimum stress is a process attribute of a fatigue testing process which describes the minimum stress that the specimen experiences. Its value corresponds to the min peak of a fatigue waveform."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000028
<https://w3id.org/pmd/distel/DISTEL_0000028> rdf:type owl:Class ;
                                             rdfs:subClassOf obo:OBI_0001930 ;
                                             rdfs:comment "TODO add other individuals" ;
                                             rdfs:label "loading ratio type value"@en ;
                                             skos:definition "Loading ratio type value is a categorical value specification which specifies value of a loading ratio process attribute and qualitatively describes the ratio between the minumum and maximum loading (force, stress, strain) of a specimen during a fatigue testing. It is equivalent to the scalar value specification of R."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000030
<https://w3id.org/pmd/distel/DISTEL_0000030> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000008 ;
                                             rdfs:label "fatigue cycle limit"@en ;
                                             skos:definition "Fatigue cycle limit is a process attribute of a fatigue testing process which describes the maximum number of loading cycles that would be performed if the specimen does not fail (break) before undergoing this number of cycles."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000031
<https://w3id.org/pmd/distel/DISTEL_0000031> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/pmd/distel/DISTEL_0000017> ;
                                             rdfs:label "fatigue strength at cycle limit"@en ;
                                             skos:definition "Fatigue strength at cycle limit is a fatigue strength which desribes the maximum cyclic stress amplitude that a material must withstand without failure for a predetermined number of cycles."@en ;
                                             skos:example "if a material has a fatigue strength of 200 MPa at 10^6 cycles, this means that when subjected to a cyclic stress of 200 MPa, the material is expected to fail after approximately 10^6 cycles."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000032
<https://w3id.org/pmd/distel/DISTEL_0000032> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/pmd/distel/DISTEL_0000017> ;
                                             rdfs:comment "This limit is characteristic of certain ferrous (iron-based) and titanium alloys, for which the S-N curve and underlying data points level off at high cycle counts, indicating that failure is unlikely to occur below the limit. In contrast, materials like aluminium and copper typically do not exhibit a distinct endurance limit."@en ;
                                             rdfs:label "fatigue endurance limit"@en ;
                                             skos:definition "Fatigue endurance limit is a fatigue strength which desribes the maximum cyclic stress amplitude that a material must withstand without failure assuming an infinite number of load cycles."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000033
<https://w3id.org/pmd/distel/DISTEL_0000033> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000848 ;
                                             rdfs:label "knee point"@en ;
                                             skos:definition "Knee point is a mechnical property realized in a fatigue process which describes the number of cycles at which the slope of a fatigue curve changes."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000034
<https://w3id.org/pmd/distel/DISTEL_0000034> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000848 ;
                                             rdfs:label "slope of S-N curve"@en ;
                                             skos:definition "Slope of S-N curve is a mechanical property realized in the fatigue testing which defines the inclination of the S-N curve in the finite life fatigue region."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000035
<https://w3id.org/pmd/distel/DISTEL_0000035> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000008 ;
                                             rdfs:comment "For now a free text description, i.e., pointing to a value specification"@en ;
                                             rdfs:label "failure criterion"@en ;
                                             skos:definition "Failure criterion is a process attribute which describes the conditions at which a fatigue specimen is considered to be failed, i.e., no further cycles are applied."@en ;
                                             skos:example "A crack in a specimen, which exceeds certain length. A significant drop in a load which material experiences."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000036
<https://w3id.org/pmd/distel/DISTEL_0000036> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000637 ;
                                             rdfs:label "tensile fatigue testing machine"@en ;
                                             skos:definition "Tensile fatigue testing machine is a type of a fatigue testing machine which are designed to evaluate the mechanical fatigue of materials by applying repeated cyclic tension or compression loads. Such machines are primarly designed for uniaxial tension-tension or tension-compression fatigue."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000037
<https://w3id.org/pmd/distel/DISTEL_0000037> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000637 ;
                                             obo:IAO_0000119 "https://www.sciencedirect.com/science/article/pii/S0142112325002257" ;
                                             rdfs:label "ultrasonic fatigue testing machine"@en ;
                                             skos:definition "Ultrasonic fatigue testing machine is a type of a fatigue testing machine which applies load at a frequency equal to the specimen’s natural frequency."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000038
<https://w3id.org/pmd/distel/DISTEL_0000038> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/pmd/distel/DISTEL_0000045> ,
                                                             [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty obo:OBI_0000312 ;
                                                                                      owl:someValuesFrom co:PMD_0000638
                                                                                    ]
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty obo:OBI_0000312 ;
                                                                                      owl:allValuesFrom co:PMD_0000638
                                                                                    ]
                                                                                  ) ;
                                                               rdf:type owl:Class
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty obo:OBI_0000312 ;
                                                               owl:someValuesFrom co:PMD_0000638
                                                             ] ;
                                             rdfs:label "S-N curve"@en ;
                                             skos:definition "An S-N curve is a 2D data item, which is a specified output of a fatigue testing and describes an ability of a material to resist fracture under repeated, alternating loads over a finite or infinite duration."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000039
<https://w3id.org/pmd/distel/DISTEL_0000039> rdf:type owl:Class ;
                                             rdfs:subClassOf obo:IAO_0000009 ;
                                             rdfs:label "axis label of fatigue curve"@en ;
                                             skos:definition "Axis label of S-N curve is a datum label which desribes the label of the axis (x- or y-) in the S-N curve."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000040
<https://w3id.org/pmd/distel/DISTEL_0000040> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/pmd/distel/DISTEL_0000039> ;
                                             rdfs:label "y-axis label of fatigue curve"@en .


###  https://w3id.org/pmd/distel/DISTEL_0000041
<https://w3id.org/pmd/distel/DISTEL_0000041> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/pmd/distel/DISTEL_0000039> ;
                                             rdfs:label "x-axis label of fatigue curve"@en .


###  https://w3id.org/pmd/distel/DISTEL_0000042
<https://w3id.org/pmd/distel/DISTEL_0000042> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/pmd/distel/DISTEL_0000038> ;
                                             rdfs:label "semi-log S-N curve"@en ;
                                             skos:definition "Semi-log S-N curve is a type of S-N curve, where both x-axis (the time variable) is given in logarithmic scale, while y-axis (loading variable) is given in its original scale."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000043
<https://w3id.org/pmd/distel/DISTEL_0000043> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/pmd/distel/DISTEL_0000038> ;
                                             rdfs:label "log-log S-N curve"@en ;
                                             skos:definition "Log-log S-N curve is a type of S-N curve, where both x-axis (the time variable) and y-axis (loading variable) are given in the logarithm scale."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000044
<https://w3id.org/pmd/distel/DISTEL_0000044> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/pmd/distel/DISTEL_0000038> ;
                                             rdfs:label "linear S-N curve"@en ;
                                             skos:definition "Linear S-N curve is a type of S-N curve, where both x-axis (the time variable) and y-axis (loading variable) are given in its original scaling."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000045
<https://w3id.org/pmd/distel/DISTEL_0000045> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000502 ;
                                             rdfs:label "fatigue life curve"@en ;
                                             skos:definition "Fatigue life curve is a 2D data item which is an output from a fatigue testing process, and it is about the performance of a material under cyclic load."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000046
<https://w3id.org/pmd/distel/DISTEL_0000046> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/pmd/distel/DISTEL_0000045> ;
                                             rdfs:label "ε-N curve"@en .


###  https://w3id.org/pmd/distel/DISTEL_0000047
<https://w3id.org/pmd/distel/DISTEL_0000047> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000638 ;
                                             obo:IAO_0000119 "https://en.wikipedia.org/wiki/Rolling_contact_fatigue" ;
                                             rdfs:label "rolling contact fatigue testing process"@en ;
                                             skos:altLabel "RCF"@en ;
                                             skos:definition "Rolling contact fatigue (RCF) testing is a fatigue testing process that evaluates material performance under repeated loading while applying high cyclic contact pressure and sliding until failure (pitting/spalling) occurs."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000048
<https://w3id.org/pmd/distel/DISTEL_0000048> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000638 ;
                                             obo:IAO_0000119 "Tensile fatigue testing process is a fatigue testing process  that evaluates material performance under repeated loading while applying cyclic, axial tensile stress. The test can involve constant amplitude or variable amplitude loading."@en ;
                                             rdfs:label "tensile fatigue testing process"@en .


###  https://w3id.org/pmd/distel/DISTEL_0000049
<https://w3id.org/pmd/distel/DISTEL_0000049> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0000005 ;
                                             rdfs:label "number of sustained loading cycles"@en ;
                                             skos:altLabel "fatigue lifetime"@en ;
                                             skos:definition "Number of sustained loading cycles is a behavioral characteristic of a material in a single fatigue testing process, and it describes how many cycles of applied load the material can sustain before failure."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000050
<https://w3id.org/pmd/distel/DISTEL_0000050> rdf:type owl:Class ;
                                             rdfs:subClassOf co:PMD_0025020 ;
                                             owl:disjointWith <https://w3id.org/pmd/distel/DISTEL_0000052> ;
                                             rdfs:comment """The axioms about NOT having a failure: 
Option 1 (easy): SHACL Shape specifically for this class, stating that it cannot have fatigue specimen failure as occurent part.
Option 2 (ontology advanced): make an equv. class axiom with some and only to make a an exaustive and close list of triples the class is allowed to have. Then, if the failure is an occurent part, it will be automatically inferred as \".. test with failed specimen\". If no failure is explicitly given, but all the other essential triples are asserted, it will be classified as \".. test with run out\""""@en ;
                                             rdfs:label "single fatigue testing process with run out"@en ;
                                             skos:definition "Single fatigue testing process with run out is a single fatigue testing process in which the specimen did not fail when the fatigue cycle limit is reached."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000051
<https://w3id.org/pmd/distel/DISTEL_0000051> rdf:type owl:Class ;
                                             rdfs:subClassOf obo:BFO_0000015 ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty obo:BFO_0000132 ;
                                                               owl:someValuesFrom co:PMD_0025020
                                                             ] ;
                                             rdfs:comment "The \"failure\" is defined based on the free text failure criterion from process attributes"@en ;
                                             rdfs:label "fatigue specimen failure"@en ;
                                             skos:definition "Fatigue specimen failure is a process which is an occurent part of a sinlge fatigue testing process. If fatigue specimen failure took place, it means that the defined failure criterion has been satisfied."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000052
<https://w3id.org/pmd/distel/DISTEL_0000052> rdf:type owl:Class ;
                                             owl:equivalentClass [ owl:intersectionOf ( co:PMD_0025020
                                                                                        [ rdf:type owl:Restriction ;
                                                                                          owl:onProperty obo:BFO_0000117 ;
                                                                                          owl:someValuesFrom <https://w3id.org/pmd/distel/DISTEL_0000051>
                                                                                        ]
                                                                                      ) ;
                                                                   rdf:type owl:Class
                                                                 ] ;
                                             rdfs:subClassOf co:PMD_0025020 ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty obo:BFO_0000117 ;
                                                               owl:someValuesFrom <https://w3id.org/pmd/distel/DISTEL_0000051>
                                                             ] ;
                                             rdfs:comment "For determining the S-N curve for a specific material, the query must contain outputs and/or process attributes of instances of this class!"@en ;
                                             rdfs:label "single fatigue testing process with failed specimen"@en ;
                                             skos:definition "Single fatigue testing process with failed specimen is a process of determining number of cycles a sinlge specimen can withstand under given load. The prerequisite for this process is a failed specimen, i.e., the fatigue specimen failure must be an occurent part of the single fatigue testing process."@en .


###  https://w3id.org/pmd/distel/DISTEL_0000053
<https://w3id.org/pmd/distel/DISTEL_0000053> rdf:type owl:Class ;
                                             owl:equivalentClass [ owl:intersectionOf ( obo:BFO_0000030
                                                                                        [ rdf:type owl:Restriction ;
                                                                                          owl:onProperty obo:RO_0000087 ;
                                                                                          owl:someValuesFrom [ owl:intersectionOf ( obo:OBI_0000067
                                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                                      owl:onProperty obo:BFO_0000054 ;
                                                                                                                                      owl:someValuesFrom <https://w3id.org/pmd/distel/DISTEL_0000050>
                                                                                                                                    ]
                                                                                                                                  ) ;
                                                                                                               rdf:type owl:Class
                                                                                                             ]
                                                                                        ]
                                                                                      ) ;
                                                                   rdf:type owl:Class
                                                                 ] ;
                                             rdfs:subClassOf obo:BFO_0000030 ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty obo:RO_0000087 ;
                                                               owl:someValuesFrom [ owl:intersectionOf ( obo:OBI_0000067
                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                           owl:onProperty obo:BFO_0000054 ;
                                                                                                           owl:someValuesFrom <https://w3id.org/pmd/distel/DISTEL_0000050>
                                                                                                         ]
                                                                                                       ) ;
                                                                                    rdf:type owl:Class
                                                                                  ]
                                                             ] ;
                                             rdfs:label "fatigue test run out"@en ;
                                             skos:definition "Fatigue test run out is an object which has an evaluant role in a single fatigue testing process and does not experience failure (defined by a failure criterion) after reaching the planned number number of cycles"@en .


###  https://w3id.org/pmd/tto/TTO_0000005
<https://w3id.org/pmd/tto/TTO_0000005> rdf:type owl:Class ;
                                       rdfs:subClassOf co:PMD_0000848 ;
                                       rdfs:comment """Dimensional analysis: L
Unit (e.g. SI): mm"""@en ,
                                                    """Hinweis: Die Dehnung kann mit verschiedenen Kanälen gemessen werden (z. B. bei Verwendung von einem oder zwei Dehnungsmesserkanälen); in der Regel wird als Dehnungswert der mittlere Durchschnittswert der beteiligten Kanäle angegeben, falls zutreffend.

Hinweis: Die optische Längenänderungsmessung kann eine besondere Methode der Datenspeicherung erfordern."""@de ,
                                                    """Note: The extension might be measured using different channels (e.g. when using one or two extensometer channels); usually, the mean average value of involved channels is given as extension value, if applicable.

Note: Optical extensometry may require a specific data storage method."""@en ;
                                       rdfs:isDefinedBy <https://w3id.org/pmd/tto> ;
                                       rdfs:label "Verlängerung (der Extensometer-Messlänge)"@de ,
                                                  "extension"@en ;
                                       rdfs:seeAlso <https://w3id.org/pmd/co/2.0.8/Extension> ;
                                       skos:definition "Increase in the extensometer gauge length at any moment during a test"@en ,
                                                       "Zunahme der Extensometer-Messlänge zu einem beliebigen Zeitpunkt eines Versuchs"@de ;
                                       co:definitionSource "DIN EN ISO 6892-1:2019" .


###  https://w3id.org/pmd/tto/TTO_0000009
<https://w3id.org/pmd/tto/TTO_0000009> rdf:type owl:Class ;
                                       rdfs:subClassOf co:PMD_0000952 ;
                                       rdfs:isDefinedBy <https://w3id.org/pmd/tto> ;
                                       rdfs:label "Streckgrenze"@de ,
                                                  "yield strength"@en ;
                                       rdfs:seeAlso <https://w3id.org/pmd/tto/YieldStrength> ;
                                       skos:definition "Wenn der metallische Werkstoff diese Eigenschaft aufweist: die Spannung zu einem bestimmten Zeitpunkt während des Versuchs bei dem eine plastische Verformung ohne Zunahme der Kraft auftritt"@de ,
                                                       "when the metallic material exhibits a yield phenomenon, stress corresponding to the point reached during the test at which plastic deformation occurs without any increase in the force"@en ;
                                       co:definitionSource "DIN EN ISO 6892-1:2019"@en .


###  https://w3id.org/pmd/tto/TTO_0000012
<https://w3id.org/pmd/tto/TTO_0000012> rdf:type owl:Class ;
                                       rdfs:subClassOf co:PMD_0020199 ;
                                       rdfs:isDefinedBy <https://w3id.org/pmd/tto> ;
                                       rdfs:label "Querschnittsfläche"@de ,
                                                  "cross section area"@en ;
                                       rdfs:seeAlso <https://w3id.org/pmd/co/2.0.8/CrossSectionArea> ;
                                       skos:definition "Die Querschnittsfläche ist die Fläche eines Schnittes oder eines rechtwinklig geschnittenen oder gebrochenen Stücks eines Objektes in Bezug auf eine Achse."@de ,
                                                       "The cross section area is an area of a cutting or piece of an object cut off or broken at right angles or related to an axis."@en ;
                                       co:definitionSource <https://www.merriam-webster.com/dictionary/cross%20section> .


###  https://w3id.org/pmd/tto/TTO_0000017
<https://w3id.org/pmd/tto/TTO_0000017> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/pmd/tto/TTO_0000019> ;
                                       rdfs:isDefinedBy <https://w3id.org/pmd/tto> ;
                                       rdfs:label "Extensometer-Messlänge"@de ,
                                                  "extensometer gauge length"@en ;
                                       rdfs:seeAlso <https://w3id.org/pmd/tto/ExtensometerGaugeLength> ;
                                       skos:definition """Anfangsmesslänge des Dehnungsaufnehmers (Extensometer), die zum Messen der Verlängerung benutzt wird

Anmerkung: Für die Bestimmung mehrerer Eigenschaften, die (teilweise oder vollständig) von der Verlängerung abhängig sind, z. B. R_p, A_e oder A_g, ist die Verwendung eines Extensometers zwingend erforderlich."""@de ,
                                                       """initial gauge length of the extensometer used for measurement of extension

Note: For the determination of several properties which are based (partly or complete) on extension, e. g. R_p, A_e or A_g, the use of an extensometer is mandatory."""@en ;
                                       co:definitionSource "DIN EN ISO 6892-1:2019"@en ;
                                       co:symbol "L_e"@en .


###  https://w3id.org/pmd/tto/TTO_0000018
<https://w3id.org/pmd/tto/TTO_0000018> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/pmd/tto/TTO_0000019> ;
                                       rdfs:isDefinedBy <https://w3id.org/pmd/tto> ;
                                       rdfs:label "Messlänge nach dem Bruch"@de ,
                                                  "final gauge length after fracture"@en ;
                                       rdfs:seeAlso <https://w3id.org/pmd/tto/FinalGaugeLengthAfterFracture> ;
                                       skos:definition "Länge zwischen den Marken zur Kennzeichnung der Messlänge auf der Probe, die nach dem Bruch bei Raumtemperatur gemessen wird, nachdem die beiden Probenbruchstücke sorgfältig so zusammengefügt wurden, dass ihre Achsen in einer Geraden liegen"@de ,
                                                       "length between gauge length marks on the test piece measured after rupture, at room temperature, the two pieces having been carefully fitted back together so that their axes lie in a straight line"@en ;
                                       co:definitionSource "DIN EN ISO 6892-1:2019"@en ;
                                       co:symbol "L_u"@en .


###  https://w3id.org/pmd/tto/TTO_0000019
<https://w3id.org/pmd/tto/TTO_0000019> rdf:type owl:Class ;
                                       rdfs:subClassOf co:PMD_0040001 ;
                                       rdfs:isDefinedBy <https://w3id.org/pmd/tto> ;
                                       rdfs:label "Messlänge"@de ,
                                                  "gauge length"@en ;
                                       rdfs:seeAlso <https://w3id.org/pmd/tto/GaugeLength> ;
                                       skos:definition "Länge des parallelen Teils der Probe, an dem zu einem beliebigen Zeitpunkt während des Versuchs die Verlängerung gemessen wird"@de ,
                                                       "length of the parallel portion of the test piece on which elongation is measured at any moment during the test"@en ;
                                       co:definitionSource "DIN EN ISO 6892-1:2019"@en ;
                                       co:symbol "L"@en .


###  https://w3id.org/pmd/tto/TTO_0000022
<https://w3id.org/pmd/tto/TTO_0000022> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/pmd/tto/TTO_0000009> ;
                                       rdfs:isDefinedBy <https://w3id.org/pmd/tto> ;
                                       rdfs:label "lower yield strength"@en ,
                                                  "untere Streckgrenze"@de ;
                                       rdfs:seeAlso <https://w3id.org/pmd/tto/LowerYieldStrength> ;
                                       skos:definition "kleinste Spannung während des plastischen Fließens, wobei Einschwingerscheinungen nicht berücksichtigt werden"@de ,
                                                       "lowest value of stress during plastic yielding, ignoring any initial transient effects"@en ;
                                       co:definitionSource "DIN EN ISO 6892-1:2019"@en ;
                                       co:symbol "R_eL"@en .


###  https://w3id.org/pmd/tto/TTO_0000028
<https://w3id.org/pmd/tto/TTO_0000028> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://w3id.org/pmd/tto/TTO_0000019> ;
                                       rdfs:isDefinedBy <https://w3id.org/pmd/tto> ;
                                       rdfs:label "Anfangsmesslänge"@de ,
                                                  "original gauge length"@en ;
                                       rdfs:seeAlso <https://w3id.org/pmd/tto/OriginalGaugeLength> ;
                                       skos:definition "Länge zwischen den Marken zur Kennzeichnung der Messlänge auf der Probe, die vor dem Versuch bei Raumtemperatur gemessen wird"@de ,
                                                       "length between gauge length marks on the test piece measured at room temperature before the test"@en ;
                                       co:definitionSource "DIN EN ISO 6892-1:2019"@en ;
                                       co:symbol "L_o"@en .


###  https://w3id.org/pmd/tto/TTO_0000031
<https://w3id.org/pmd/tto/TTO_0000031> rdf:type owl:Class ;
                                       rdfs:subClassOf co:PMD_0040001 ;
                                       rdfs:isDefinedBy <https://w3id.org/pmd/tto> ;
                                       rdfs:label "Parallele Länge"@de ,
                                                  "parallel length"@en ;
                                       rdfs:seeAlso <https://w3id.org/pmd/tto/ParallelLength> ;
                                       skos:definition """Länge des parallelen reduzierten Querschnitts der Probe

Anmerkung: Bei unbearbeiteten Proben tritt an die Stelle der parallelen Länge der Abstand zwischen den Einspannungen."""@de ,
                                                       """length of the parallel reduced section of the test piece

Note: The concept of parallel length is replaced by the concept of distance between grips for unmachined test pieces."""@en ;
                                       co:definitionSource "DIN EN ISO 6892-1:2019"@en ;
                                       co:symbol "L_c"@en .


