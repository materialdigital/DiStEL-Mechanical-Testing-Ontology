###  https://w3id.org/pmd/distel/DISTEL_0000009
<https://w3id.org/pmd/distel/DISTEL_0000009> rdf:type owl:Class ;
                                             owl:equivalentClass [ rdf:type owl:Class ;
                                                                   owl:oneOf ( <https://w3id.org/pmd/distel/DISTEL_0000011>
                                                                               <https://w3id.org/pmd/distel/DISTEL_0000012>
                                                                             )
                                                                 ] ;
                                             rdfs:subClassOf obo:OBI_0001930 ;
                                             rdfs:label "fatigue control type value"@en ;
                                             skos:definition "Fatigue control type value is a categorical value specification which describes the variable (stress or strain) that remains constant during the fatigue testing."@en .


