<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/pmd/distel/components/distel-mech-tensile-test.owl/"
     xml:base="https://w3id.org/pmd/distel/components/distel-mech-tensile-test.owl/"
     xmlns:co="https://w3id.org/pmd/co/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:doap="http://usefulinc.com/ns/doap#"
     xmlns:qudt="http://qudt.org/schema/qudt/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:oboInOwl="http://www.geneontology.org/formats/oboInOwl#">
    <owl:Ontology rdf:about="https://w3id.org/pmd/distel/components/distel-mech-tensile-test.owl">
        <owl:imports rdf:resource="https://w3id.org/pmd/distel/components/distel-mech-shared.owl"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000060 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0000060">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000502"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000974"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">engineering stress-strain curve</rdfs:label>
        <skos:definition xml:lang="en">Engineering stress-strain curve is a 2D data-item which is a specified output of a tensile testing process. The x-axis is a strain, i.e., the change of gauge length relative to its inital value, the y-axis is an engineering stress, i.e., force normalized to the initial cross-sectional area of a specimen.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000061 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0000061">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000502"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000974"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">true stress-strain curve</rdfs:label>
        <skos:definition xml:lang="en">True stress-strain curve is a 2D data-item which is a specified output of a tensile testing process. The x-axis is a strain, i.e., the change of gauge length relative to its inital value, the y-axis is a true stress, i.e., force normalized to the instantaneous cross-sectional area of a specimen.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000062 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0000062">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000502"/>
        <rdfs:label xml:lang="en">true stress-compression curve</rdfs:label>
        <skos:definition xml:lang="en">True stress-compression curve is a 2D data-item which is a specified output of a compression testing process. The x-axis is a compression, i.e., the change of gauge length relative to its inital value, the y-axis is a true stress, i.e., force normalized to the instantaneous cross-sectional area of a specimen.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000063 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0000063">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000581"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000009"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000008"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0020127"/>
                                        <owl:someValuesFrom>
                                            <owl:Class>
                                                <owl:intersectionOf rdf:parseType="Collection">
                                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000967"/>
                                                    <owl:Restriction>
                                                        <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                                                        <owl:someValuesFrom>
                                                            <owl:Class>
                                                                <owl:intersectionOf rdf:parseType="Collection">
                                                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBI_0001931"/>
                                                                    <owl:Restriction>
                                                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000039"/>
                                                                        <owl:hasValue rdf:resource="http://purl.obolibrary.org/obo/UO_0000027"/>
                                                                    </owl:Restriction>
                                                                    <owl:Restriction>
                                                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0001937"/>
                                                                        <owl:someValuesFrom>
                                                                            <rdfs:Datatype>
                                                                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                                                                                <owl:withRestrictions rdf:parseType="Collection">
                                                                                    <rdf:Description>
                                                                                        <xsd:minExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">25</xsd:minExclusive>
                                                                                    </rdf:Description>
                                                                                </owl:withRestrictions>
                                                                            </rdfs:Datatype>
                                                                        </owl:someValuesFrom>
                                                                    </owl:Restriction>
                                                                </owl:intersectionOf>
                                                            </owl:Class>
                                                        </owl:someValuesFrom>
                                                    </owl:Restriction>
                                                </owl:intersectionOf>
                                            </owl:Class>
                                        </owl:someValuesFrom>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000581"/>
        <rdfs:label xml:lang="en">hot compression testing process</rdfs:label>
        <skos:definition>Hot compression testing process is a compression testing process performed at elevated temperature, i.e., it has a process attribute which refers to temperature with numerical value above 25°C.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000064 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0000064">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000848"/>
        <obo:IAO_0000119>DIN 50106</obo:IAO_0000119>
        <obo:IAO_0000119>TODO add upper and lower</obo:IAO_0000119>
        <rdfs:comment xml:lang="en">Very important note:  not added directly under yield strength from TTO, because the other yield strength is implicitly TENSILE yield strength (so much on unambigious defintions in an ontology.... )</rdfs:comment>
        <rdfs:label xml:lang="en">compressive yield strength</rdfs:label>
        <skos:definition xml:lang="en">compressive stress at the elastic-plastic transition in the case of deformation with no or only minor increase in compressive stress.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000065 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0000065">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000848"/>
        <obo:IAO_0000119>DIN 50106</obo:IAO_0000119>
        <rdfs:label xml:lang="en">compressive proof strength</rdfs:label>
        <skos:definition xml:lang="en">compressive stress at a specified plastic strain</skos:definition>
        <co:symbol xml:lang="en">R_dp</co:symbol>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000066 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0000066">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/distel/DISTEL_0000065"/>
        <rdfs:label xml:lang="en">compressive proof strength dp02</rdfs:label>
        <skos:definition xml:lang="en">stress at which the plastic compression  is equal to 0.2 percent of the extensometer gauge length.</skos:definition>
        <co:symbol xml:lang="en">R_dp0,2</co:symbol>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000067 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0000067">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000848"/>
        <obo:IAO_0000119>DIN 50106</obo:IAO_0000119>
        <rdfs:label xml:lang="en">compressive strength</rdfs:label>
        <skos:definition>compressive stress at the point when the test piece separates into two (or more) pieces</skos:definition>
        <co:symbol xml:lang="en">R_dB</co:symbol>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0025001 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0025001">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000974"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000009"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000008"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0020127"/>
                                        <owl:someValuesFrom>
                                            <owl:Class>
                                                <owl:intersectionOf rdf:parseType="Collection">
                                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000967"/>
                                                    <owl:Restriction>
                                                        <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                                                        <owl:someValuesFrom>
                                                            <owl:Class>
                                                                <owl:intersectionOf rdf:parseType="Collection">
                                                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBI_0001931"/>
                                                                    <owl:Restriction>
                                                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000039"/>
                                                                        <owl:hasValue rdf:resource="http://purl.obolibrary.org/obo/UO_0000027"/>
                                                                    </owl:Restriction>
                                                                    <owl:Restriction>
                                                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0001937"/>
                                                                        <owl:someValuesFrom>
                                                                            <rdfs:Datatype>
                                                                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                                                                                <owl:withRestrictions rdf:parseType="Collection">
                                                                                    <rdf:Description>
                                                                                        <xsd:minExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">25</xsd:minExclusive>
                                                                                    </rdf:Description>
                                                                                </owl:withRestrictions>
                                                                            </rdfs:Datatype>
                                                                        </owl:someValuesFrom>
                                                                    </owl:Restriction>
                                                                </owl:intersectionOf>
                                                            </owl:Class>
                                                        </owl:someValuesFrom>
                                                    </owl:Restriction>
                                                </owl:intersectionOf>
                                            </owl:Class>
                                        </owl:someValuesFrom>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000974"/>
        <rdfs:label xml:lang="en">hot tensile testing process</rdfs:label>
        <skos:definition xml:lang="en">Hot tensile testing process is a tensile testing process performed at elevated temperature, i.e., it has a process attribute which refers to temperature with numerical value above 25°C.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0025002 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0025002">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000952"/>
        <rdfs:label xml:lang="en">fracture strength</rdfs:label>
        <skos:definition xml:lang="en">Fracture strength is a strength which describes the stress at the breaking point of a test piece.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0025004 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0025004">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000848"/>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Strain_hardening_exponent</obo:IAO_0000119>
        <rdfs:label xml:lang="en">strain hardening exponent</rdfs:label>
        <skos:altLabel xml:lang="en">strain hardening index</skos:altLabel>
        <skos:definition xml:lang="en">Strain hardening exponent is a mechanical property which quantifies the ability of a material to become stronger due to strain hardening. It is a exponent relation between true stress and true strain.</skos:definition>
        <co:symbol>n</co:symbol>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0025006 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0025006">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000008"/>
        <rdfs:label xml:lang="en">target strain</rdfs:label>
        <skos:definition xml:lang="en">Target strain is a process attribute of a compression test or a hot tensile test which defines the final strain that a test piece should achieve in the test.</skos:definition>
    </owl:Class>
</rdf:RDF>



