    <!-- https://w3id.org/pmd/distel/DISTEL_0025003 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0025003">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000008"/>
        <rdfs:comment xml:lang="en">Defined in Distel, cause TTO developers are unable to fix their errors since months.
TODO import from TTO at some point (hopefully)</rdfs:comment>
        <rdfs:label xml:lang="en">strain rate</rdfs:label>
        <skos:definition xml:lang="en">heating rate is a process attribute which describes the change in length of a specimen participating in a process over time.</skos:definition>
    </owl:Class>
