    </owl:Class>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000100 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0000100">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/distel/DISTEL_0000057"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000637"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">motor</rdfs:label>
        <skos:definition xml:lang="en">Motor of a fatigue testing machine is a part of such machine which is essential for the applicaiton of loading on a sample.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0025001 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0025001"/>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0025007 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0025007">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0025020"/>
        <rdfs:label xml:lang="en">load increasing fatigue testing process</rdfs:label>
        <skos:definition xml:lang="en">Load increasing fatigue testing process is a single fatigue testing process in which the load is gradually increased by a given load increment value after a given number of cycles.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0025008 -->

    <owl:Class rdf:about="https://w3id.org/pmd/distel/DISTEL_0025008">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/distel/DISTEL_0000018"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
