    <!-- https://w3id.org/pmd/distel/DISTEL_0000001 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000001">
        <rdfs:label xml:lang="en">axial loading</rdfs:label>
        <skos:altLabel xml:lang="en">push-pull loading</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000002 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000002">
        <rdfs:label xml:lang="en">tension-tension loading</rdfs:label>
        <skos:definition>Tension-tension loading is a type of axial loading. A specimen is pulled in tension and then returned to its original length.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000003 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000003">
        <rdfs:label xml:lang="en">tension-compression loading</rdfs:label>
        <skos:definition>Tension-compression loading is a type of axial loading. A specimen is pulled in tension and then compressed.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000004 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000004">
        <rdfs:label xml:lang="en">bending loading</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000005 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000005">
        <rdfs:label xml:lang="en">torsional loading</rdfs:label>
        <skos:altLabel xml:lang="en">twist loading</skos:altLabel>
        <skos:definition xml:lang="en">During a fatigue test with torsional loading type the specimen is twisted and experienced shear stress.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000006 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000006">
        <rdfs:label xml:lang="en">rotating bending loading</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000007 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000007">
        <rdfs:label xml:lang="en">shear loading</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000011 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000011">
        <rdfs:label xml:lang="en">strain-controlled</rdfs:label>
        <skos:altLabel xml:lang="en">displacement-controlled</skos:altLabel>
        <skos:definition xml:lang="en">A fatigue test is considered stain-controlled if the strain ratio of a strain that the sample exhibits is kept constant.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000012 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000012">
        <rdfs:label xml:lang="en">stress-controlled</rdfs:label>
        <skos:altLabel xml:lang="en">force-controlled</skos:altLabel>
        <skos:altLabel xml:lang="en">load-controlled</skos:altLabel>
        <skos:definition xml:lang="en">A fatigue test is considered stress-controlled if a laod/force ratio of a load exerted on a specimen is kept constant.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000015 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000015">
        <rdfs:label xml:lang="en">compression-compression loading</rdfs:label>
        <skos:definition xml:lang="en">Compression-compression loading is a type of axial loading. A specimen is compresed and then returned to its original length.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000016 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000016">
