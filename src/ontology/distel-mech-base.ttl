###  https://w3id.org/pmd/tto/TTO_0000029
<https://w3id.org/pmd/tto/TTO_0000029> rdf:type owl:Class ;
                                       rdfs:subClassOf co:PMD_0050153 ;
                                       rdfs:isDefinedBy <https://w3id.org/pmd/tto> ;
                                       rdfs:label "Anfangs-Dicke"@de ,
