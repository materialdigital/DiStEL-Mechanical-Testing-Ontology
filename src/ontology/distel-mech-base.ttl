                                                                                                        owl:unionOf ( obo:BFO_0000016
                                                                                                                      co:PMD_0000005
                                                                                                                    )
                                                                                                      ]
                                                                                                      [ rdf:type owl:Restriction ;
                                                                                                        owl:onProperty obo:BFO_0000054 ;
                                                                                                        owl:someValuesFrom co:PMD_0000950
                                                                                                      ]
                                                                                                    ) ;
                                                                                 rdf:type owl:Class
                                                                               ]
                                                          ]
