AnnotationAssertion(rdfs:label <https://w3id.org/pmd/tto/TTO_0000053> "Zugfestigkeit"@de)
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/tto/TTO_0000053> "tensile strength"@en)
