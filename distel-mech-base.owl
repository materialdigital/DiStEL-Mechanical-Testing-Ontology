    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020111">
        <rdfs:label xml:lang="en">martensite</rdfs:label>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020117 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020117">
        <rdfs:label xml:lang="en">aggregate state solid</rdfs:label>
        <skos:definition xml:lang="en">A state where the bonds between entities transmit shear forces.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020118 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020118">
        <rdfs:label xml:lang="en">aggregate state liquid</rdfs:label>
        <skos:definition xml:lang="en">A state where the bonds of the entities transmit no shear force.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020119 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020119">
        <rdfs:label xml:lang="en">aggregate state gaseous</rdfs:label>
        <skos:definition xml:lang="en">A state where the entities have no bonding.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020120 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020120">
        <rdfs:label xml:lang="en">aggregate state plasma</rdfs:label>
        <skos:definition xml:lang="en">An aggregate state where the entities are atom nuclei and have no bonds.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020121 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020121">
        <rdfs:label xml:lang="en">aggregate state atom gas</rdfs:label>
        <skos:definition xml:lang="en">A gaseous state where the gas entities are atoms.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020122 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020122">
        <rdfs:label xml:lang="en">aggregate state supercritical fluid</rdfs:label>
        <skos:definition xml:lang="en">A state with strong bindings between entities that do not transmit shear force.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020123 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020123">
        <rdfs:label xml:lang="en">aggregate state mesomorphic</rdfs:label>
        <skos:definition xml:lang="en">A state where some bonds transmit shear stresses and some do not.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020124 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020124">
        <rdfs:label xml:lang="en">aggregate state suprafluid</rdfs:label>
        <skos:definition xml:lang="en">A state with frictionless binding that transmits no shear force between entities.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020125 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020125">
        <rdfs:label xml:lang="en">aggregate state suprasolid</rdfs:label>
        <skos:definition xml:lang="en">A state that exhibits suprafluid and solid properties.</skos:definition>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020217 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020217">
        <rdfs:label xml:lang="en">short range order</rdfs:label>
        <skos:definition xml:lang="en">periodic arrangement of structural features up to a few entities</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020218 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020218">
        <rdfs:label xml:lang="en">medium range order</rdfs:label>
        <skos:definition xml:lang="en">periodic arrangement of structural features of many entities</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020219 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020219">
        <rdfs:label xml:lang="en">long range order</rdfs:label>
        <skos:definition xml:lang="en">periodic arrangement of structural features of virtually all entities</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020242 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020242">
        <rdfs:label xml:lang="en">no range order</rdfs:label>
        <skos:definition xml:lang="en">no periodic arrangement of structural features of entites</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000001 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000001">
        <rdfs:label xml:lang="en">axial loading</rdfs:label>
        <skos:altLabel xml:lang="en">push-pull loading</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000002 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000002">
        <rdfs:label xml:lang="en">tension-tension loading</rdfs:label>
        <skos:definition>Tension-tension loading is a type of axial loading. A specimen is pulled in tension and then returned to its original length.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000003 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000003">
        <rdfs:label xml:lang="en">tension-compression loading</rdfs:label>
        <skos:definition>Tension-compression loading is a type of axial loading. A specimen is pulled in tension and then compressed.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000004 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000004">
        <rdfs:label xml:lang="en">bending loading</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000005 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000005">
        <rdfs:label xml:lang="en">torsional loading</rdfs:label>
        <skos:altLabel xml:lang="en">twist loading</skos:altLabel>
        <skos:definition xml:lang="en">During a fatigue test with torsional loading type the specimen is twisted and experienced shear stress.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000006 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000006">
        <rdfs:label xml:lang="en">rotating bending loading</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000007 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000007">
        <rdfs:label xml:lang="en">shear loading</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000011 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000011">
        <rdfs:label xml:lang="en">strain-controlled</rdfs:label>
        <skos:altLabel xml:lang="en">displacement-controlled</skos:altLabel>
        <skos:definition xml:lang="en">A fatigue test is considered stain-controlled if the strain ratio of a strain that the sample exhibits is kept constant.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000012 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000012">
        <rdfs:label xml:lang="en">stress-controlled</rdfs:label>
        <skos:altLabel xml:lang="en">force-controlled</skos:altLabel>
        <skos:altLabel xml:lang="en">load-controlled</skos:altLabel>
        <skos:definition xml:lang="en">A fatigue test is considered stress-controlled if a laod/force ratio of a load exerted on a specimen is kept constant.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000015 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000015">
        <rdfs:label xml:lang="en">compression-compression loading</rdfs:label>
        <skos:definition xml:lang="en">Compression-compression loading is a type of axial loading. A specimen is compresed and then returned to its original length.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000016 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000016">
        <rdf:type rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
        <rdfs:comment>TODO there is abn abbreviation AP in PMDco</rdfs:comment>
        <rdfs:label xml:lang="en">room temperature</rdfs:label>
        <skos:altLabel xml:lang="en">RT</skos:altLabel>
        <skos:definition xml:lang="en">Room temperature is a value specification, which vaguely describes the temperature usually during some process. It leaves a room for interpretation which exact temperature is meant.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/distel/DISTEL_0000029 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/distel/DISTEL_0000029">
        <rdf:type rdf:resource="https://w3id.org/pmd/distel/DISTEL_0000028"/>
        <rdfs:comment>TODO write defintion</rdfs:comment>
        <rdfs:label xml:lang="en">fully reversed loading</rdfs:label>
    </owl:NamedIndividual>
    


