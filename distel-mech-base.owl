        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">nature constant</rdfs:label>
        <skos:definition xml:lang="en">A nature constant is a generically dependent continuant whose value, magintude or configuration is determined by nature including physics and mathematics.</skos:definition>
        <skos:example xml:lang="en">Examples of nature constants are the speed of light, pi, and the 14 Bravais lattices.</skos:example>
        <co:PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</co:PMD_0000060>
    </owl:Class>
    


