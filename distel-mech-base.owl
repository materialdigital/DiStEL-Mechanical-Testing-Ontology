                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020140"/>
        <rdfs:comment xml:lang="en">A Portion Of Matter that consists of only rhodium atoms.</rdfs:comment>
        <rdfs:label xml:lang="en">portion of rhodium</rdfs:label>
        <skos:definition xml:lang="en">A &apos;portion of rhodium&apos; is a &apos;portion of pure chemical element&apos; that &apos;consists of&apos; only chebi:rhodium atom.</skos:definition>
    </owl:Class>
    


